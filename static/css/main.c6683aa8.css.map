.section-3 {
  position: relative;
  overflow: hidden;
  background: #fff;
  padding: 28px 0 56px;
  min-height: 800px;
}

.section-3__content {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20px;
  min-height: 720px;
}

.section-3__left {
  flex: 0 0 58%;
  display: flex;
  justify-content: center;
  padding-top: 34px;
  padding-left: 40px;
}

.section-3__text-block {
  width: 100%;
  max-width: 650px;
  text-align: center;
}

.section-3__icon {
  display: flex;
  justify-content: center;
  margin-bottom: 6px;
}

.section-3__icon-svg {
  width: 78px;
  height: 78px;
  fill: none;
  stroke: #5d7128;
  stroke-width: 3;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.section-3__title {
  margin: 0 0 10px;
  color: #5d7128;
  font-size: 66px;
  line-height: 1;
  font-weight: 800;
  letter-spacing: 0.5px;
  text-transform: uppercase;
  font-family: Impact, Haettenschweiler, "Arial Narrow Bold", sans-serif;
}

.section-3__card {
  width: 100%;
  max-width: 590px;
  margin: 0 auto;
  background: #5d7128;
  padding: 30px 22px 30px;
  box-shadow: 14px 12px 16px rgba(0, 0, 0, 0.18);
}

.section-3__text {
  margin: 0;
  color: #ffffff;
  font-size: 34px;
  line-height: 1.28;
  font-weight: 400;
  text-align: left;
  font-family: Arial, Helvetica, sans-serif;
}

.section-3__right {
  position: relative;
  flex: 0 0 42%;
  min-height: 760px;
  display: flex;
  justify-content: flex-end;
  align-items: flex-start;
  padding-right: 0;
}

.section-3__image-ring {
  position: absolute;
  top: 8px;
  right: -110px;
  width: 760px;
  height: 760px;
  border-radius: 50%;
}

.section-3__image-ring::before {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 7px dashed #5d7128;
  box-sizing: border-box;
}

.section-3__image {
  position: absolute;
  top: 34px;
  left: 34px;
  width: calc(100% - 68px);
  height: calc(100% - 68px);
  border-radius: 50%;
  object-fit: cover;
  display: block;
}

.section-3__decor {
  position: absolute;
  z-index: 1;
  pointer-events: none;
}

.section-3__decor--top-right {
  top: -84px;
  right: -72px;
  width: 290px;
  height: 290px;
  border-radius: 50%;
  border: 58px solid rgba(93, 113, 40, 0.1);
  border-left-color: transparent;
  border-bottom-color: transparent;
  transform: rotate(8deg);
}

.section-3__decor--bottom-left {
  left: -62px;
  bottom: 56px;
  width: 184px;
  height: 184px;
  border-radius: 50%;
  border: 58px solid #5d7128;
  border-top-color: transparent;
  border-right-color: transparent;
  transform: rotate(45deg);
}

@media (max-width: 1400px) {
  .section-3__left {
    padding-left: 24px;
  }

  .section-3__title {
    font-size: 58px;
  }

  .section-3__text {
    font-size: 30px;
  }

  .section-3__image-ring {
    width: 660px;
    height: 660px;
    right: -90px;
  }
}

@media (max-width: 1200px) {
  .section-3 {
    min-height: auto;
    padding: 40px 20px 56px;
  }

  .section-3__content {
    gap: 32px;
  }

  .section-3__left {
    flex: 0 0 52%;
    padding-left: 0;
  }

  .section-3__right {
    flex: 0 0 48%;
    min-height: 620px;
  }

  .section-3__title {
    font-size: 52px;
  }

  .section-3__text {
    font-size: 26px;
  }

  .section-3__image-ring {
    width: 560px;
    height: 560px;
    right: -60px;
  }

  .section-3__decor--bottom-left {
    width: 150px;
    height: 150px;
    border-width: 46px;
  }
}

@media (max-width: 992px) {
  .section-3 {
    padding: 36px 16px 48px;
  }

  .section-3__content {
    flex-direction: column;
    align-items: center;
    min-height: auto;
  }

  .section-3__left,
  .section-3__right {
    flex: 1 1 auto;
    width: 100%;
  }

  .section-3__left {
    padding-top: 0;
  }

  .section-3__right {
    min-height: auto;
    justify-content: center;
    padding-bottom: 24px;
  }

  .section-3__text-block {
    max-width: 760px;
  }

  .section-3__card {
    max-width: 100%;
  }

  .section-3__text {
    text-align: center;
  }

  .section-3__image-ring {
    position: relative;
    top: 0;
    right: 0;
    width: min(92vw, 620px);
    height: min(92vw, 620px);
    margin-top: 12px;
  }

  .section-3__decor--bottom-left {
    bottom: 22px;
  }
}

@media (max-width: 600px) {
  .section-3__icon-svg {
    width: 62px;
    height: 62px;
  }

  .section-3__title {
    font-size: 42px;
  }

  .section-3__card {
    padding: 22px 16px;
  }

  .section-3__text {
    font-size: 21px;
    line-height: 1.35;
  }

  .section-3__image-ring {
    width: min(94vw, 430px);
    height: min(94vw, 430px);
  }

  .section-3__image-ring::before {
    border-width: 6px;
  }

  .section-3__image {
    top: 24px;
    left: 24px;
    width: calc(100% - 48px);
    height: calc(100% - 48px);
  }

  .section-3__decor--top-right {
    width: 180px;
    height: 180px;
    border-width: 36px;
    top: -56px;
    right: -46px;
  }

  .section-3__decor--bottom-left {
    width: 110px;
    height: 110px;
    border-width: 34px;
    left: -34px;
    bottom: 40px;
  }
}