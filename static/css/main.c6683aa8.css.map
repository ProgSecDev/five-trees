/* src/Sections/Section-2.css */
.section-2 {
  position: relative;
  overflow: visible;
  background: #fff;
  padding: 84px 36px 72px;
}

.section-2__top-image-wrap {
  position: absolute;
  top: -132px;
  right: 110px;
  z-index: 4;
  pointer-events: none;
}

.section-2__top-image {
  display: block;
  width: 265px;
  max-width: 100%;
  height: auto;
  filter: drop-shadow(8px 10px 14px rgba(0, 0, 0, 0.22));
}

.section-2__content {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 56px;
  min-height: 620px;
}

.section-2__left {
  flex: 0 0 54%;
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.section-2__circle-frame {
  width: 630px;
  height: 630px;
  border: 7px solid #5d7128;
  border-radius: 50%;
  padding: 18px;
  box-sizing: border-box;
}

.section-2__circle-inner {
  width: 100%;
  height: 100%;
  border: 7px solid #5d7128;
  border-radius: 50%;
  overflow: hidden;
  background: #ffffff;
}

.section-2__circle-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.section-2__right {
  flex: 0 0 40%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-top: 42px;
}

.section-2__mission-icon {
  margin-bottom: 8px;
}

.section-2__mission-svg {
  width: 72px;
  height: 72px;
  fill: none;
  stroke: #5d7128;
  stroke-width: 3;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.section-2__title {
  margin: 0 0 10px;
  color: #5d7128;
  font-size: 56px;
  line-height: 1;
  font-weight: 800;
  text-transform: uppercase;
  font-family: Impact, Haettenschweiler, "Arial Narrow Bold", sans-serif;
}

.section-2__card {
  width: 100%;
  max-width: 470px;
  background: #5d7128;
  padding: 18px 14px;
  box-shadow: 12px 12px 18px rgba(0, 0, 0, 0.18);
}

.section-2__text {
  margin: 0;
  color: #ffffff;
  font-size: 24px;
  line-height: 1.4;
  font-weight: 400;
  text-align: center;
}

.section-2__shape {
  position: absolute;
  right: -70px;
  bottom: -88px;
  width: 330px;
  height: 330px;
  border-radius: 50%;
  border: 68px solid rgba(93, 113, 40, 0.1);
  border-top-color: transparent;
  border-left-color: transparent;
  transform: rotate(8deg);
  z-index: 1;
}

@media (max-width: 1200px) {
  .section-2__content {
    gap: 36px;
  }

  .section-2__circle-frame {
    width: 520px;
    height: 520px;
  }

  .section-2__top-image-wrap {
    right: 48px;
    top: -118px;
  }

  .section-2__top-image {
    width: 220px;
  }

  .section-2__title {
    font-size: 48px;
  }

  .section-2__text {
    font-size: 21px;
  }
}

@media (max-width: 992px) {
  .section-2 {
    padding: 110px 24px 56px;
  }

  .section-2__top-image-wrap {
    top: -92px;
    right: 24px;
  }

  .section-2__top-image {
    width: 180px;
  }

  .section-2__content {
    flex-direction: column;
    align-items: center;
    min-height: auto;
  }

  .section-2__left,
  .section-2__right {
    flex: 1 1 auto;
    width: 100%;
  }

  .section-2__left {
    justify-content: center;
  }

  .section-2__right {
    margin-top: 0;
  }

  .section-2__circle-frame {
    width: min(88vw, 520px);
    height: min(88vw, 520px);
  }

  .section-2__card {
    max-width: 100%;
  }
}

@media (max-width: 600px) {
  .section-2 {
    padding: 92px 16px 48px;
  }

  .section-2__top-image-wrap {
    top: -70px;
    right: 12px;
  }

  .section-2__top-image {
    width: 130px;
  }

  .section-2__circle-frame {
    width: min(92vw, 390px);
    height: min(92vw, 390px);
    padding: 12px;
    border-width: 5px;
  }

  .section-2__circle-inner {
    border-width: 5px;
  }

  .section-2__title {
    font-size: 38px;
  }

  .section-2__text {
    font-size: 18px;
  }

  .section-2__shape {
    width: 220px;
    height: 220px;
    border-width: 44px;
    right: -40px;
    bottom: -40px;
  }
}