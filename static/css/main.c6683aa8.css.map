.about-header {
  width: 100%;
  font-family: Arial, Helvetica, sans-serif;
  color: #ffffff;
}

.about-header__hero {
  position: relative;
  min-height: 535px;
  background-position: center;
  background-repeat: no-repeat;
  background-size: cover;
  overflow: hidden;
}

.about-header__overlay {
  position: absolute;
  inset: 0;
  background: rgba(38, 29, 19, 0.35);
}

.about-header__nav {
  position: absolute;
  top: 96px;
  right: 0;
  z-index: 3;
  display: flex;
  align-items: center;
  gap: 46px;
  padding: 18px 28px 18px 32px;
  background: #5d7128;
}

.about-header__nav-link {
  color: #ffffff;
  text-decoration: none;
  font-size: 24px;
  font-weight: 800;
  line-height: 1;
  letter-spacing: 0.5px;
  text-transform: uppercase;
  font-family: Impact, Haettenschweiler, "Arial Narrow Bold", sans-serif;
}

.about-header__nav-link.is-active {
  color: #c7d86b;
}

.about-header__hero-content {
  position: relative;
  z-index: 2;
  min-height: 535px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 34px;
  text-align: center;
  padding: 80px 20px 40px;
}

.about-header__title {
  margin: 0;
  color: #ffffff;
  font-size: 74px;
  font-weight: 800;
  line-height: 1;
  letter-spacing: 1px;
  text-transform: uppercase;
  font-family: Impact, Haettenschweiler, "Arial Narrow Bold", sans-serif;
  text-shadow: 0 2px 8px rgba(0, 0, 0, 0.18);
}

.about-header__button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 260px;
  height: 126px;
  padding: 0 36px;
  background: #5d7128;
  color: #ffffff;
  text-decoration: none;
  font-size: 34px;
  font-weight: 800;
  line-height: 1;
  letter-spacing: 0.5px;
  text-transform: uppercase;
  font-family: Impact, Haettenschweiler, "Arial Narrow Bold", sans-serif;
  transition: opacity 0.2s ease;
}

.about-header__button:hover {
  opacity: 0.92;
}

.about-header__about {
  position: relative;
  background: #5d7128;
  padding: 26px 42px 70px;
  overflow: hidden;
}

.about-header__about-inner {
  position: relative;
  max-width: 1080px;
}

.about-header__about-title {
  margin: 0 0 10px;
  color: #ffffff;
  font-size: 62px;
  font-weight: 800;
  line-height: 1;
  letter-spacing: 1px;
  text-transform: uppercase;
  font-family: Impact, Haettenschweiler, "Arial Narrow Bold", sans-serif;
}

.about-header__about-text {
  margin: 0;
  max-width: 1040px;
  color: #ffffff;
  font-size: 28px;
  font-weight: 400;
  line-height: 1.4;
  letter-spacing: 0.2px;
}

.about-header__cheese-art {
  position: absolute;
  right: 18px;
  bottom: -54px;
  width: 240px;
  height: 180px;
  pointer-events: none;
}

.about-header__cheese {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 210px;
  height: 88px;
  background: linear-gradient(180deg, #fbf3df 0%, #efe2c2 100%);
  border-radius: 8px 8px 0 0;
  box-shadow:
    inset 0 -10px 0 rgba(0, 0, 0, 0.06),
    inset 0 6px 0 rgba(255, 255, 255, 0.3);
}

.about-header__cheese::before {
  content: "";
  position: absolute;
  inset: 10px 14px auto 14px;
  height: 18px;
  background:
    radial-gradient(circle at 20px 8px, rgba(255, 255, 255, 0.6) 0 4px, transparent 4px),
    radial-gradient(circle at 66px 10px, rgba(255, 255, 255, 0.6) 0 4px, transparent 4px),
    radial-gradient(circle at 120px 7px, rgba(255, 255, 255, 0.6) 0 4px, transparent 4px),
    radial-gradient(circle at 160px 9px, rgba(255, 255, 255, 0.6) 0 4px, transparent 4px);
  opacity: 0.4;
}

.about-header__olive {
  position: absolute;
  right: 72px;
  bottom: 64px;
  width: 70px;
  height: 70px;
  background: radial-gradient(circle at 30% 30%, #7f4b20 0%, #4d2a11 58%, #2c1609 100%);
  border-radius: 50%;
  box-shadow:
    inset -8px -10px 10px rgba(0, 0, 0, 0.28),
    inset 8px 8px 12px rgba(255, 255, 255, 0.18);
}

.about-header__olive::after {
  content: "";
  position: absolute;
  top: 14px;
  left: 18px;
  width: 18px;
  height: 10px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.28);
  transform: rotate(-18deg);
}

@media (max-width: 1200px) {
  .about-header__title {
    font-size: 60px;
  }

  .about-header__about-title {
    font-size: 52px;
  }

  .about-header__about-text {
    font-size: 24px;
  }

  .about-header__nav {
    gap: 28px;
  }

  .about-header__nav-link {
    font-size: 20px;
  }
}

@media (max-width: 900px) {
  .about-header__hero {
    min-height: 460px;
  }

  .about-header__hero-content {
    min-height: 460px;
    gap: 24px;
    padding-top: 120px;
  }

  .about-header__nav {
    top: 20px;
    left: 20px;
    right: 20px;
    justify-content: center;
    flex-wrap: wrap;
    gap: 18px;
    padding: 14px 18px;
  }

  .about-header__title {
    font-size: 42px;
  }

  .about-header__button {
    min-width: 210px;
    height: 92px;
    font-size: 28px;
  }

  .about-header__about {
    padding: 24px 24px 90px;
  }

  .about-header__about-title {
    font-size: 40px;
  }

  .about-header__about-text {
    font-size: 21px;
  }

  .about-header__cheese-art {
    transform: scale(0.82);
    transform-origin: bottom right;
    right: -10px;
  }
}

@media (max-width: 600px) {
  .about-header__hero {
    min-height: 400px;
  }

  .about-header__hero-content {
    min-height: 400px;
    padding: 120px 16px 32px;
  }

  .about-header__nav-link {
    font-size: 16px;
  }

  .about-header__title {
    font-size: 30px;
  }

  .about-header__button {
    min-width: 180px;
    height: 72px;
    font-size: 22px;
  }

  .about-header__about-title {
    font-size: 32px;
  }

  .about-header__about-text {
    font-size: 18px;
    line-height: 1.5;
  }

  .about-header__cheese-art {
    display: none;
  }
}